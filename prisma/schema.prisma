generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id          Int      @id @default(autoincrement())
  description String
  amount      Float
  type        String
  category    String
  date        String
  createdAt   DateTime @default(now())
}
